<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>3D Flight Simulator</title>
    <style>
        body {
            margin: 0;
            padding: 0;
            background-color: #000;
            color: #fff;
            font-family: sans-serif;
            overflow: hidden;
        }
        #canvas {
            width: 100vw;
            height: 100vh;
            display: block;
        }
        #hud {
            position: absolute;
            top: 20px;
            left: 20px;
            background: rgba(0, 0, 0, 0.6);
            padding: 15px;
            border-radius: 8px;
            border: 1px solid #00ff66;
            font-family: monospace;
            pointer-events: none;
        }
        .controls {
            position: absolute;
            bottom: 20px;
            left: 50%;
            transform: translateX(-50%);
            background: rgba(0,0,0,0.7);
            padding: 10px 20px;
            border-radius: 20px;
            font-size: 14px;
            pointer-events: none;
            text-align: center;
        }
    </style>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
</head>
<body>

    <div id="hud">
        <div style="color: #00ff66; font-weight: bold; margin-bottom: 5px;">FLIGHT DATA</div>
        Speed: <span id="speedUI">0</span> knots<br>
        Altitude: <span id="altUI">0</span> ft
    </div>

    <div class="controls">
        Controls: <b>W/S</b> = Pitch (Up/Down) | <b>A/D</b> = Roll (Left/Right) | <b>R/F</b> = Throttle (Speed Up/Down)
    </div>

    <canvas id="canvas"></canvas>

    <script>
        // --- 3D Scene Setup ---
        const scene = new THREE.Scene();
        scene.background = new THREE.Color(0x87ceeb); // Sky blue
        scene.fog = new THREE.FogExp2(0x87ceeb, 0.015);

        const camera = new THREE.PerspectiveCamera(60, window.innerWidth / window.innerHeight, 0.1, 1000);
        const renderer = new THREE.WebGLRenderer({ canvas: document.getElementById('canvas'), antialias: true });
        renderer.setSize(window.innerWidth, window.innerHeight);

        // Lighting
        const ambientLight = new THREE.AmbientLight(0xffffff, 0.6);
        scene.add(ambientLight);
        const dirLight = new THREE.DirectionalLight(0xffffff, 0.8);
        dirLight.position.set(100, 300, 100);
        scene.add(dirLight);

        // --- Endless Green Terrain ---
        const terrainGeo = new THREE.PlaneGeometry(2000, 2000, 64, 64);
        terrainGeo.rotateX(-Math.PI / 2);
        
        // Add low mountains/hills
        const pos = terrainGeo.attributes.position;
        for (let i = 0; i < pos.count; i++) {
            const x = pos.getX(i);
            const z = pos.getZ(i);
            // Simple mathematical hill generation
            const y = Math.sin(x * 0.01) * Math.cos(z * 0.01) * 15 + Math.sin(x * 0.005) * 20;
            pos.setY(i, y - 10); 
        }
        terrainGeo.computeVertexNormals();

        const terrainMat = new THREE.MeshLambertMaterial({ color: 0x2e8b57, flatShading: true });
        const terrain = new THREE.Mesh(terrainGeo, terrainMat);
        scene.add(terrain);

        // --- Simple School-Safe Glider Airplane ---
        const planeGroup = new THREE.Group();
        
        // Fuselage
        const bodyGeo = new THREE.ConeGeometry(1, 6, 8);
        bodyGeo.rotateX(Math.PI / 2);
        const bodyMat = new THREE.MeshLambertMaterial({ color: 0xffffff });
        const body = new THREE.Mesh(bodyGeo, bodyMat);
        planeGroup.add(body);

        // Wings
        const wingGeo = new THREE.BoxGeometry(12, 0.1, 1.5);
        const wingMat = new THREE.MeshLambertMaterial({ color: 0xff3333 });
        const wings = new THREE.Mesh(wingGeo, wingMat);
        wings.position.set(0, 0, 0.5);
        planeGroup.add(wings);

        scene.add(planeGroup);

        // --- Flight Physics Variables ---
        let flightState = {
            speed: 30,
            pitchSpeed: 0,
            rollSpeed: 0,
            altitude: 40
        };

        // Initialize positions
        planeGroup.position.set(0, flightState.altitude, 0);

        // --- Keyboard Controls ---
        const keys = {};
        window.addEventListener('keydown', (e) => keys[e.key.toLowerCase()] = true);
        window.addEventListener('keyup', (e) => keys[e.key.toLowerCase()] = false);

        // --- Main Game Loop ---
        const clock = new THREE.Clock();

        function animate() {
            requestAnimationFrame(animate);
            const delta = clock.getDelta();

            // Handle Input Handling
            if (keys['w']) planeGroup.rotateX(-1.2 * delta); // Pitch Down
            if (keys['s']) planeGroup.rotateX(1.2 * delta);  // Pitch Up
            if (keys['a']) planeGroup.rotateZ(1.5 * delta);  // Roll Left
            if (keys['d']) planeGroup.rotateZ(-1.5 * delta); // Roll Right
            
            if (keys['r']) flightState.speed = Math.min(60, flightState.speed + 10 * delta); // Throttle up
            if (keys['f']) flightState.speed = Math.max(10, flightState.speed - 10 * delta); // Throttle down

            // Forward Flight Movement Direction
            planeGroup.translateZ(-flightState.speed * delta);

            // Ground collision safety boundary
            if (planeGroup.position.y < -5) {
                planeGroup.position.y = -5;
            }

            // Keep camera fixed behind the cockpit
            const relativeCameraOffset = new THREE.Vector3(0, 3, 12);
            const cameraOffset = relativeCameraOffset.applyMatrix4(planeGroup.matrixWorld);
            camera.position.x = cameraOffset.x;
            camera.position.y = cameraOffset.y;
            camera.position.z = cameraOffset.z;
            camera.lookAt(planeGroup.position);

            // Update UI Counters
            document.getElementById('speedUI').innerText = Math.round(flightState.speed);
            document.getElementById('altUI').innerText = Math.round((planeGroup.position.y + 10) * 10);

            renderer.render(scene, camera);
        }

        // Handle Responsive Screen Resizing
        window.addEventListener('resize', () => {
            camera.aspect = window.innerWidth / window.innerHeight;
            camera.updateProjectionMatrix();
            renderer.setSize(window.innerWidth, window.innerHeight);
        });

        animate();
    </script>
</body>
</html>
